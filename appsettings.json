{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServerHost": "localhost",
  "ServersConfiguration": {
    "GameBaseDir": "/var/lib/cs2-base",
    "ServersBaseDir": "/var/lib/cs2-instances/",
    "PluginsBaseDir": "/var/lib/cs2-plugins",
    "NetworkMode": "bridge",
    "DnsServers": [
      "1.1.1.1",
      "8.8.8.8"
    ],
    "DefaultEnvVariables": {
      "STEAMAPPVALIDATE": "0",
      "CS2_SERVER_HIBERNATE": "1",
      "CS2_LAN": "0",
      "CS2_PW": "server-pw",
      "CS2_MAXPLAYERS": "20",
      "CS2_STARTMAP": "de_inferno",
      "CS2_GAMEALIAS": "competitive",
      "CS2_ADDITIONAL_ARGS": "-tickrate 128",
      "CS2_BOT_QUOTA_MODE": "fill",
      "CS2_BOT_DIFFICULTY": "2",
      "TV_AUTORECORD": "1",
      "TV_ENABLE": "1",
      "TV_PW": "tv-pw",
      "TV_RELAY_PW": "tv-relaypw",
      "TV_MAXRATE": "64",
      "TV_DELAY": "30",
      "CS2_LOG": "on",
      "CS2_LOG_MONEY": "1",
      "CS2_LOG_DETAIL": "3",
      "CS2_LOG_ITEMS": "0",
      "CS2_WORKSHOP_COLLECTION": "3731062534",
      "CS2_WORKSHOP_START_MAP": "205239595"
    }
  }
}